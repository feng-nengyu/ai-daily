<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>AI 日报归档</title>
  <style>
    :root {
      --bg: #fafaf9; --fg: #1c1917; --muted: #78716c; --border: #e7e5e4;
      --card: #ffffff; --accent: #0369a1; --link: #0369a1;
      --score-high: #15803d; --score-mid: #ca8a04; --score-low: #6b7280;
      --today-accent: #0369a1; --fav-accent: #d97706;
      /* source category palette */
      --src-lab: #15803d; --src-framework: #7c3aed; --src-expert: #0369a1;
      --src-media: #be185d; --src-github: #1f2937; --src-paper: #b45309;
      --src-community: #ea580c; --src-other: #6b7280;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0; padding: 0; background: var(--bg); color: var(--fg);
      font-family: -apple-system, BlinkMacSystemFont, "PingFang SC",
        "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
      line-height: 1.6;
    }
    header.page {
      padding: 28px 24px 16px; border-bottom: 1px solid var(--border);
      background: var(--card); position: sticky; top: 0; z-index: 20;
    }
    header.page h1 { margin: 0 0 6px; font-size: 24px; }
    header.page .meta {
      margin: 0; color: var(--muted); font-size: 13px;
      display: flex; gap: 12px; flex-wrap: wrap; align-items: center;
    }
    header.page .meta strong { color: var(--fg); font-weight: 600; }
    main { max-width: 880px; margin: 0 auto; padding: 24px; }

    /* TOC */
    nav.toc {
      background: var(--card); border: 1px solid var(--border);
      border-radius: 8px; padding: 14px 16px; margin-bottom: 28px;
    }
    nav.toc h2 {
      margin: 0 0 10px; font-size: 13px; text-transform: uppercase;
      letter-spacing: 1px; color: var(--muted);
    }
    nav.toc .chips { display: flex; flex-wrap: wrap; gap: 8px; }
    nav.toc a {
      display: inline-block; padding: 4px 10px; border-radius: 12px;
      background: var(--bg); border: 1px solid var(--border); font-size: 13px;
      color: var(--fg); text-decoration: none;
    }
    nav.toc a:hover { background: #e7e5e4; }
    nav.toc a.today-chip { border-color: var(--today-accent); color: var(--today-accent); font-weight: 600; }
    nav.toc a.fav-chip { border-color: var(--fav-accent); color: var(--fav-accent); }
    nav.toc a .n { color: var(--muted); margin-left: 4px; font-weight: normal; }

    /* bands */
    section.band { margin-bottom: 32px; }
    section.band > h2.band-title {
      font-size: 14px; text-transform: uppercase; letter-spacing: 1px;
      color: var(--muted); margin: 0 0 12px; padding-bottom: 6px;
      border-bottom: 1px solid var(--border);
      display: flex; align-items: center; gap: 10px;
    }
    section.band.today > h2.band-title {
      color: var(--today-accent); border-bottom-color: var(--today-accent);
    }
    section.band.favorites > h2.band-title {
      color: var(--fav-accent); border-bottom-color: var(--fav-accent);
    }
    section.band .cards { display: flex; flex-direction: column; gap: 16px; }

    /* per-date archive group */
    details.date-group {
      background: var(--card); border: 1px solid var(--border);
      border-radius: 8px; margin-bottom: 12px;
    }
    details.date-group > summary {
      cursor: pointer; padding: 12px 16px; font-weight: 600;
      list-style: none; display: flex; align-items: center; gap: 8px;
      user-select: none;
    }
    details.date-group > summary::-webkit-details-marker { display: none; }
    details.date-group > summary::before {
      content: "▶"; font-size: 11px; color: var(--muted);
      transition: transform 0.2s;
    }
    details.date-group[open] > summary::before { transform: rotate(90deg); }
    details.date-group > summary .n {
      color: var(--muted); font-weight: normal; font-size: 13px; margin-left: auto;
    }
    details.date-group > .cards {
      padding: 0 16px 16px;
      display: flex; flex-direction: column; gap: 12px;
    }

    /* card */
    article.card {
      background: var(--card); border: 1px solid var(--border);
      border-radius: 8px; padding: 20px; box-shadow: 0 1px 2px rgba(0,0,0,0.04);
      position: relative;
    }
    section.band.today article.card { border-left: 3px solid var(--today-accent); }
    details.date-group article.card { box-shadow: none; }

    button.star {
      position: absolute; top: 12px; right: 12px;
      width: 32px; height: 32px; border-radius: 50%;
      border: 1px solid var(--border); background: var(--card);
      cursor: pointer; font-size: 18px; line-height: 1;
      color: var(--muted); transition: all 0.15s;
      display: flex; align-items: center; justify-content: center;
    }
    button.star:hover { color: var(--fav-accent); border-color: var(--fav-accent); }
    button.star.starred {
      color: var(--fav-accent); border-color: var(--fav-accent);
      background: #fef3c7;
    }

    .card-head {
      display: flex; align-items: flex-start; gap: 16px;
      justify-content: space-between; margin-bottom: 12px;
      padding-right: 44px;  /* leave room for star button */
    }
    .card-head h2 { margin: 0; font-size: 18px; line-height: 1.4; flex: 1; }
    .card-head h2 a { color: var(--fg); text-decoration: none; }
    .card-head h2 a:hover { color: var(--link); text-decoration: underline; }
    .badges { display: flex; gap: 8px; align-items: center; flex-shrink: 0; }
    .score {
      display: inline-flex; align-items: center; justify-content: center;
      min-width: 28px; height: 28px; padding: 0 8px;
      border-radius: 14px; color: white; font-weight: 600; font-size: 13px;
    }
    .score.high { background: var(--score-high); }
    .score.mid  { background: var(--score-mid); }
    .score.low  { background: var(--score-low); }

    /* source badge: larger, color-coded by category */
    .source {
      font-size: 13px; padding: 4px 10px; border-radius: 6px;
      font-weight: 500; color: white; white-space: nowrap;
    }
    .source.cat-lab        { background: var(--src-lab); }
    .source.cat-framework  { background: var(--src-framework); }
    .source.cat-expert     { background: var(--src-expert); }
    .source.cat-media      { background: var(--src-media); }
    .source.cat-github     { background: var(--src-github); }
    .source.cat-paper      { background: var(--src-paper); }
    .source.cat-community  { background: var(--src-community); }
    .source.cat-other      { background: var(--src-other); }

    .tags { display: flex; flex-wrap: wrap; gap: 6px; margin: 8px 0 12px; }
    .tag {
      font-size: 12px; padding: 2px 8px; background: #e0f2fe; color: #075985;
      border-radius: 4px;
    }
    .innovation {
      font-size: 16px; font-weight: 500; margin: 12px 0;
      padding: 12px 16px; background: #fef3c7; border-left: 3px solid #ca8a04;
    }
    dl.details { margin: 12px 0; }
    dl.details dt {
      font-weight: 600; color: var(--muted); font-size: 12px;
      text-transform: uppercase; letter-spacing: 0.5px; margin-top: 8px;
    }
    dl.details dd { margin: 4px 0 0 0; }
    .card-foot {
      display: flex; align-items: center; gap: 16px; flex-wrap: wrap;
      margin-top: 16px; padding-top: 12px; border-top: 1px solid var(--border);
      font-size: 14px;
    }
    .card-foot .date { color: var(--muted); }
    .card-foot .links { color: var(--muted); flex: 1; word-break: break-all; }
    .card-foot .links a { color: var(--link); }
    .cta {
      margin-left: auto; padding: 6px 14px; background: var(--accent);
      color: white; text-decoration: none; border-radius: 4px; font-size: 14px;
    }
    .cta:hover { background: #075985; }
    .empty {
      text-align: center; padding: 32px 24px; color: var(--muted);
      background: var(--card); border: 1px dashed var(--border); border-radius: 8px;
    }
    .toolbar {
      display: flex; gap: 12px; align-items: center;
      font-size: 13px; margin-left: auto;
    }
    .toolbar button {
      background: transparent; border: 1px solid var(--border);
      padding: 4px 10px; border-radius: 4px; cursor: pointer;
      color: var(--muted); font-size: 12px;
    }
    .toolbar button:hover { background: var(--bg); color: var(--fg); }
    @media (max-width: 600px) {
      .card-head { flex-direction: column; gap: 8px; padding-right: 44px; }
      .badges { align-self: flex-start; }
      header.page h1 { font-size: 20px; }
    }
  </style>
</head>
<body>
  <header class="page">
    <h1>AI 日报归档</h1>
    <p class="meta">
      今日新增 <strong>{{ today|length }}</strong> 条 ·
      归档 <strong>{{ archive_total }}</strong> 条（{{ archive_groups|length }} 天）·
      生成于 {{ generated_at }}
    </p>
  </header>
  <main>
    {% macro card(a) -%}
    {% set lbl = a.source|label %}
    <article class="card" data-url="{{ a.url }}">
      <button class="star" aria-label="收藏" data-url="{{ a.url }}" onclick="toggleStar(this)">☆</button>
      <div class="card-head">
        <h2><a href="{{ a.url }}" target="_blank" rel="noopener">{{ a.title }}</a></h2>
        <div class="badges">
          <span class="score {{ 'high' if a.score.score >= 8 else 'mid' if a.score.score >= 6 else 'low' }}">{{ a.score.score }}</span>
          <span class="source cat-{{ lbl.category }}" title="{{ a.source }}">{{ lbl.short }}</span>
        </div>
      </div>
      {% if a.score.tags %}
      <div class="tags">
        {% for t in a.score.tags %}<span class="tag">{{ t }}</span>{% endfor %}
      </div>
      {% endif %}
      <p class="innovation">{{ a.summary.innovation }}</p>
      <dl class="details">
        <dt>技术方案</dt><dd>{{ a.summary.approach }}</dd>
        <dt>关键数据</dt><dd>{{ a.summary.metrics }}</dd>
        <dt>为什么值得关注</dt><dd>{{ a.summary.why_relevant }}</dd>
      </dl>
      <footer class="card-foot">
        <span class="date">{{ a.published_at.strftime('%Y-%m-%d') }}</span>
        {% set extra_link = a.summary.links or '' %}
        {% if '://' in extra_link and extra_link != a.url %}
        <span class="links">补充：<a href="{{ extra_link }}" target="_blank" rel="noopener">{{ extra_link }}</a></span>
        {% endif %}
        <a class="cta" href="{{ a.url }}" target="_blank" rel="noopener">阅读原文 →</a>
      </footer>
    </article>
    {%- endmacro %}

    <nav class="toc">
      <h2>目录</h2>
      <div class="chips">
        <a class="fav-chip" href="#favorites">⭐ 我的收藏 <span class="n" id="toc-fav-count">0</span></a>
        <a class="today-chip" href="#today">今日新增 <span class="n">{{ today|length }}</span></a>
        {% for date_str, group in archive_groups %}
          <a href="#archive-{{ date_str }}" onclick="openArchive('{{ date_str }}')">{{ date_str }} <span class="n">{{ group|length }}</span></a>
        {% endfor %}
      </div>
    </nav>

    <section class="band favorites" id="favorites" style="display:none">
      <h2 class="band-title">⭐ 我的收藏 <span class="n" id="fav-count">0</span>
        <span class="toolbar">
          <button onclick="clearFavorites()" title="清空全部收藏">清空收藏</button>
        </span>
      </h2>
      <div class="cards" id="favorites-cards"></div>
    </section>

    <section class="band today" id="today">
      <h2 class="band-title">今日新增 <span class="n">({{ today|length }})</span></h2>
      {% if today %}
        <div class="cards">
          {% for a in today %}{{ card(a) }}{% endfor %}
        </div>
      {% else %}
        <p class="empty">本批次无新条目。可能是同一天已经 render 过、或者新条目尚未通过 score ≥ 阈值。</p>
      {% endif %}
    </section>

    <section class="band archive">
      <h2 class="band-title">归档（最近 {{ within_days }} 天）</h2>
      {% if archive_groups %}
        {% for date_str, group in archive_groups %}
          <details class="date-group" id="archive-{{ date_str }}"{% if loop.first %} open{% endif %}>
            <summary>{{ date_str }} <span class="n">{{ group|length }} 条</span></summary>
            <div class="cards">
              {% for a in group %}{{ card(a) }}{% endfor %}
            </div>
          </details>
        {% endfor %}
      {% else %}
        <p class="empty">归档暂时为空。</p>
      {% endif %}
    </section>
  </main>

  <script>
    // ---- favorites via localStorage ----
    const STAR_PREFIX = 'ai-daily:star:';

    function isStarred(url) {
      return localStorage.getItem(STAR_PREFIX + url) === '1';
    }

    function setStarred(url, on) {
      if (on) localStorage.setItem(STAR_PREFIX + url, '1');
      else    localStorage.removeItem(STAR_PREFIX + url);
    }

    function getStarredUrls() {
      const out = new Set();
      for (let i = 0; i < localStorage.length; i++) {
        const k = localStorage.key(i);
        if (k && k.startsWith(STAR_PREFIX)) out.add(k.slice(STAR_PREFIX.length));
      }
      return out;
    }

    function refreshAllStarStates() {
      document.querySelectorAll('button.star').forEach(b => {
        const on = isStarred(b.dataset.url);
        b.textContent = on ? '★' : '☆';
        b.classList.toggle('starred', on);
      });
    }

    function refreshFavoritesSection() {
      const section = document.getElementById('favorites');
      const container = document.getElementById('favorites-cards');
      const count = document.getElementById('fav-count');
      const tocCount = document.getElementById('toc-fav-count');
      container.innerHTML = '';
      const starred = getStarredUrls();
      let n = 0;
      // Walk only non-favorites cards as the source-of-truth; clone matching ones.
      document.querySelectorAll('main > section.band:not(.favorites) article.card').forEach(card => {
        if (starred.has(card.dataset.url)) {
          const clone = card.cloneNode(true);
          // Re-bind the star button in the clone so its onclick still works.
          const cloneStar = clone.querySelector('.star');
          if (cloneStar) {
            cloneStar.textContent = '★';
            cloneStar.classList.add('starred');
          }
          container.appendChild(clone);
          n++;
        }
      });
      count.textContent = n;
      tocCount.textContent = n;
      section.style.display = n > 0 ? '' : 'none';
    }

    function toggleStar(btn) {
      const url = btn.dataset.url;
      setStarred(url, !isStarred(url));
      refreshAllStarStates();
      refreshFavoritesSection();
    }

    function clearFavorites() {
      if (!confirm('清空所有收藏？此操作只清你这台设备的浏览器，不影响别人。')) return;
      const starred = Array.from(getStarredUrls());
      starred.forEach(u => setStarred(u, false));
      refreshAllStarStates();
      refreshFavoritesSection();
    }

    function openArchive(dateStr) {
      const el = document.getElementById('archive-' + dateStr);
      if (el && el.tagName === 'DETAILS') el.open = true;
    }

    document.addEventListener('DOMContentLoaded', () => {
      refreshAllStarStates();
      refreshFavoritesSection();
    });
  </script>
</body>
</html>
